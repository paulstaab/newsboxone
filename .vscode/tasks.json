{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Update Dependencies",
      "type": "shell",
      "command": "cargo update",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Lint",
      "type": "shell",
      "command": "cargo fmt --all -- --check && cargo clippy --all-targets --all-features -- -D warnings",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Backend: Test",
      "type": "shell",
      "command": "cargo test --all-targets --all-features",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Serve",
      "type": "shell",
      "command": "cargo run -- serve --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "USERNAME": "test",
          "PASSWORD": "test"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "workspace-serve"
      }
    },
    {
      "label": "Frontend: Install Dependencies",
      "type": "shell",
      "command": "npm ci",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Lint",
      "type": "shell",
      "command": "npm run format:check && npm run lint && npm run typecheck",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Test",
      "type": "shell",
      "command": "npm run test",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: E2E",
      "type": "shell",
      "command": "npm run test:e2e",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Dev",
      "type": "shell",
      "command": "npm run dev -- --hostname 0.0.0.0 --port 3000",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "workspace-serve"
      }
    },
    {
      "label": "Workspace: Serve",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Backend: Serve",
        "Frontend: Dev"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "workspace-serve"
      }
    },
    {
      "label": "Workspace: Validate",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Backend: Lint",
        "Backend: Test",
        "Frontend: Lint",
        "Frontend: Test"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
